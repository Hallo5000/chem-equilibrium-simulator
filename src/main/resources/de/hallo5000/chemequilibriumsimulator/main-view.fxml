<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: #0C1E2D;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.hallo5000.chemequilibriumsimulator.MainController">
   <children>

      <!-- Sidebar -->
      <AnchorPane layoutX="10.0" layoutY="10.0" prefWidth="190.0" style="-fx-background-color: #15344D; -fx-background-radius: 12;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="16.0" AnchorPane.rightAnchor="16.0" AnchorPane.topAnchor="20.0">

               <!-- Title -->
               <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;" text="Control Panel" />

               <!-- Buttons -->
               <HBox spacing="10.0">
                  <Button mnemonicParsing="false" onAction="#startSim" prefWidth="75.0" style="-fx-background-color: #2A6496; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12px;" text="▶  Start" />
                  <Button mnemonicParsing="false" onAction="#stopSim" prefWidth="75.0" style="-fx-background-color: #1E4A6E; -fx-text-fill: #7AAFC8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12px;" text="■  Stop" />
               </HBox>

               <!-- Slider for Particle Count A -->
               <VBox spacing="5.0">
                  <HBox spacing="5.0">
                     <Label style="-fx-text-fill: #7AAFC8; -fx-font-size: 12px;" text="Particle Count A:" />
                     <Label fx:id="ParticleCountAOutput" style="-fx-text-fill: #ffff; -fx-font-size: 12px;" text="10" />
                  </HBox>
                  <Slider fx:id="sliderParticleCountA" style="-fx-control-inner-background: #1E4A6E; -fx-accent: #2A6496;" />
               </VBox>

               <!-- Slider for Particle Count B -->
               <VBox spacing="5.0">
                  <HBox spacing="5.0">
                     <Label style="-fx-text-fill: #7AAFC8; -fx-font-size: 12px;" text="Particle Count B:" />
                     <Label fx:id="ParticleCountBOutput" style="-fx-text-fill: #ffff; -fx-font-size: 12px;" text="10" />
                  </HBox>
                  <Slider fx:id="sliderParticleCountB" style="-fx-control-inner-background: #1E4A6E; -fx-accent: #2A6496;" />
               </VBox>

               <!-- Slider for Avg Speed -->
               <VBox spacing="5.0">
                  <Label style="-fx-text-fill: #7AAFC8; -fx-font-size: 12px;" text="Avg Initial Speed" />
                  <Slider fx:id="sliderAvgSpeed" style="-fx-control-inner-background: #1E4A6E; -fx-accent: #2A6496;" />
               </VBox>

            </VBox>
         </children>
      </AnchorPane>

      <!-- Right side -->
      <SplitPane dividerPositions="0.693" orientation="VERTICAL" style="-fx-background-color: transparent; -fx-padding: 0; -fx-box-border: transparent;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="210.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <items>

            <!-- Simulation -->
            <AnchorPane fx:id="simPane" minHeight="0.0" minWidth="0.0" style="-fx-background-color: #0C1E2D; -fx-background-radius: 12; -fx-border-color: #1E4A6E; -fx-border-width: 1; -fx-border-radius: 12;">
               <children>
                  <Label style="-fx-text-fill: #7AAFC8; -fx-font-size: 12px;" text="Simulation" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="8.0" />
               </children>
            </AnchorPane>

            <!-- Stats -->
            <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #15344D; -fx-background-radius: 12; -fx-border-color: #1E4A6E; -fx-border-width: 1; -fx-border-radius: 12;">
               <children>
                  <Label style="-fx-text-fill: #7AAFC8; -fx-font-size: 12px; -fx-font-weight: bold;" text="Stats" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="8.0" />
               </children>
            </AnchorPane>

         </items>
      </SplitPane>

   </children>
</AnchorPane>
